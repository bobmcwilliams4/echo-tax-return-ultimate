{
  "name": "echo-tax-return-ultimate",
  "version": "1.0.0",
  "description": "Echo Tax Return Ultimate — AI-native tax preparation platform with 14 doctrine engines, IRS MeF e-file, Claude Opus subprocess, 220+ API endpoints",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --apply src/",
    "db:init": "bun run db/init.ts",
    "db:seed": "bun run db/seed.ts",
    "db:migrate": "bun run db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^1.13.0",
    "dayjs": "^1.11.0",
    "hono": "^4.7.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.33.0",
    "stripe": "^17.0.0",
    "twilio": "^6.0.0",
    "uuid": "^11.1.0",
    "xml2js": "^0.6.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "bun-types": "^1.2.0"
  }
}
